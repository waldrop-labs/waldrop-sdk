{
  "name": "@waldrop/sdk",
  "version": "0.1.1",
  "description": "Read-only TypeScript SDK for Waldrop - list and fetch your Walrus-stored blobs registered through the Waldrop on-chain registry.",
  "license": "MIT",
  "author": "Waldrop",
  "homepage": "https://waldrop.xyz",
  "repository": {
    "type": "git",
    "url": "https://github.com/waldrop-labs/waldrop-sdk"
  },
  "bugs": {
    "url": "https://github.com/waldrop-labs/waldrop-sdk/issues"
  },
  "keywords": [
    "waldrop",
    "walrus",
    "sui",
    "sdk",
    "blob",
    "storage",
    "seal",
    "decentralized"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"examples/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "bun run typecheck && bun run build",
    "example:list": "bun examples/listBlobs.ts",
    "example:fetch": "bun examples/fetchBlob.ts",
    "example:decrypt": "bun examples/decryptBlob.ts",
    "example:encrypt": "bun examples/encryptBlob.ts",
    "example:upload": "bun examples/uploadBlob.ts",
    "example:upload-bundle": "bun examples/uploadBundle.ts",
    "example:resume": "bun examples/resumeUpload.ts",
    "example:cost": "bun examples/costEstimate.ts",
    "example:bundle": "bun examples/bundleRoundtrip.ts"
  },
  "peerDependencies": {
    "@mysten/sui": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@mysten/seal": {
      "optional": true
    },
    "@mysten/walrus": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@mysten/seal": "^1.1.3",
    "@mysten/walrus": "^1.1.7"
  },
  "devDependencies": {
    "@mysten/seal": "^1.1.3",
    "@mysten/sui": "^2.16.3",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^6.0.3",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "nanotar": "^0.3.0"
  }
}
